@tailwind base;
@tailwind components;
@tailwind utilities;

/* ============ 设计令牌：Claude.ai 气质的暖中性 + 陶土橙 ============ */
/* 颜色以"空格分隔的 RGB 三元组"存放，配合 tailwind 的 rgb(var() / alpha)。 */

:root {
  /* 亮色：暖象牙底 + 近白卡片 + 极淡暖边界 */
  --bg: 245 244 238;          /* #F5F4EE 暖象牙 */
  --surface: 255 255 254;     /* 近白(暖) */
  --surface-2: 250 249 245;   /* 次级面 */
  --border: 230 227 218;      /* #E6E3DA 暖边界 */
  --text: 42 41 38;           /* #2A2926 暖深灰 */
  --muted: 122 118 110;       /* #7A766E 次要文字 */
  --accent: 201 100 66;       /* #C96442 陶土橙 */
  --accent-hover: 181 86 54;
  --warning: 190 80 70;       /* #BE5046 仅 BLOCK 用 */
  --success: 107 142 107;     /* 柔和鼠尾草绿，克制 */
}

.dark {
  /* 深色：暖炭底(非 GitHub 纯黑) + 暖灰卡片 */
  --bg: 38 38 36;             /* #262624 暖炭 */
  --surface: 48 48 46;        /* #30302E */
  --surface-2: 43 43 41;
  --border: 61 60 58;         /* #3D3C3A */
  --text: 232 230 224;        /* #E8E6E0 */
  --muted: 163 160 153;       /* #A3A099 */
  --accent: 209 119 87;       /* #D17757 深色下略提亮的陶土橙 */
  --accent-hover: 224 134 102;
  --warning: 224 122 110;
  --success: 127 159 122;
}

* { border-color: rgb(var(--border)); }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  background: rgb(var(--bg));
  color: rgb(var(--text));
  font-family: 'Inter', system-ui, -apple-system, 'Noto Sans SC', sans-serif;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

/* 标题用文学感衬线，但克制使用 */
h1, h2, .font-display { font-family: 'Newsreader', Georgia, 'Songti SC', serif; }

/* 细滚动条，贴合安静审美 */
::-webkit-scrollbar { width: 10px; height: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb {
  background: rgb(var(--border));
  border-radius: 99px;
  border: 3px solid rgb(var(--bg));
}
::-webkit-scrollbar-thumb:hover { background: rgb(var(--muted) / 0.5); }

/* 可见键盘焦点(可达性底线) */
:focus-visible {
  outline: 2px solid rgb(var(--accent));
  outline-offset: 2px;
  border-radius: 6px;
}

/* 尊重 reduced-motion */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: 0.001ms !important; transition-duration: 0.001ms !important; }
}

/* Markdown 排版(聊天气泡内) */
.prose-chat { line-height: 1.65; }
.prose-chat p { margin: 0.5em 0; }
.prose-chat ul, .prose-chat ol { margin: 0.5em 0; padding-left: 1.4em; }
.prose-chat li { margin: 0.2em 0; }
.prose-chat code:not(pre code) {
  background: rgb(var(--surface-2));
  border: 1px solid rgb(var(--border));
  padding: 0.1em 0.4em; border-radius: 5px;
  font-family: 'JetBrains Mono', monospace; font-size: 0.85em;
}
.prose-chat pre { border-radius: 10px; margin: 0.6em 0; overflow: hidden; }
.prose-chat a { color: rgb(var(--accent)); text-decoration: underline; text-underline-offset: 2px; }
.prose-chat h1, .prose-chat h2, .prose-chat h3 { font-family: 'Inter', sans-serif; font-weight: 600; margin: 0.8em 0 0.3em; }
.prose-chat table { border-collapse: collapse; margin: 0.6em 0; }
.prose-chat th, .prose-chat td { border: 1px solid rgb(var(--border)); padding: 0.35em 0.7em; }
