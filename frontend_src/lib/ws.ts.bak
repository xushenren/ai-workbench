// WebSocket 封装。连接 ws://{host}:9000/v1/chat/stream，分发 trace / delta / done。
import type { WsEvent } from "@/types";
import { currentToken } from "@/stores/useAuthStore";

export interface ChatHandlers {
  onTrace: (frame: Extract<WsEvent, { event: "trace" }>["frame"]) => void;
  onDelta: (text: string) => void;
  onArtifact: (a: Extract<WsEvent, { event: "artifact" }>) => void;
  onDone: (tier?: string, latencyMs?: number) => void;
  onError: (message: string) => void;
}

function wsUrl(): string {
  // 同源走代理；vite 代理已开启 ws:true。生产可改绝对地址。
  const proto = location.protocol === "https:" ? "wss" : "ws";
  return `${proto}://${location.host}/v1/chat/stream`;
}

/**
 * 发起一次流式对话。返回一个 close() 用于中断。
 * 后端不可用时触发 onError，由调用方走降级（模拟流式）。
 */
export function streamChat(
  payload: { message: string; agent_id: string; session_id: string },
  h: ChatHandlers
): () => void {
  let ws: WebSocket | null = null;
  let closed = false;

  try {
    ws = new WebSocket(wsUrl());
  } catch {
    h.onError("无法建立 WebSocket 连接");
    return () => {};
  }

  const timeout = window.setTimeout(() => {
    if (ws && ws.readyState !== WebSocket.OPEN) {
      ws.close();
      if (!closed) h.onError("连接超时");
    }
  }, 4000);

  ws.onopen = () => {
    window.clearTimeout(timeout);
    const token = currentToken();
    ws?.send(JSON.stringify(token ? { ...payload, token } : payload));
  };

  ws.onmessage = (ev) => {
    let msg: WsEvent;
    try {
      msg = JSON.parse(ev.data) as WsEvent;
    } catch {
      return; // 忽略坏帧
    }
    if (msg.event === "trace") h.onTrace(msg.frame);
    else if (msg.event === "delta") h.onDelta(msg.text);
    else if (msg.event === "artifact") h.onArtifact(msg);
    else if (msg.event === "done") {
      h.onDone(msg.tier, msg.latency_ms);
      ws?.close();
    }
  };

  ws.onerror = () => {
    window.clearTimeout(timeout);
    if (!closed) h.onError("WebSocket 连接错误");
  };

  return () => {
    closed = true;
    window.clearTimeout(timeout);
    ws?.close();
  };
}
