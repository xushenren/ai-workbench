    class FetchModelsReq(BaseModel):
        api_base: str
        api_key: str

    @app.post("/v1/models/fetch")
    async def fetch_models_ep(req: "FetchModelsReq",
                              _: "User" = Depends(require_role(Role.ADMIN))) -> Dict[str, Any]:
